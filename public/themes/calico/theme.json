    "minDisplay": {
      "attention": 5000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 5200,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 5000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 5200,
      "carrying": 3000
    },
    "dndSkipYawn": true,
    "collapseDuration": 5200,
    "yawnDuration": 8000,
    "wakeDuration": 5800,
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": {
      "x": 80,
      "y": 30,
      "w": 106,
      "h": 140
