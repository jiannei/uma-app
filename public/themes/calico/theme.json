      },
      "mini-peek": {
        "file": "calico-mini-peek.apng",
        "type": "apng"
      },
      "mini-crabwalk": {
        "file": "calico-mini-crabwalk.apng",
        "type": "apng"
      },
      "mini-enter-sleep": {
        "file": "calico-mini-sleep.apng",
        "type": "apng"
      },
      "mini-sleep": {
        "file": "calico-mini-sleep.apng",
        "type": "apng"
      }
    },
    "timings": {
      "minDisplay": {
        "mini-alert": 4000,
