  "reactions": {
    "drag": {
      "file": "calico-react-drag.apng"
    },
    "clickLeft": {
      "file": "calico-react-poke.apng",
      "duration": 2500
    },
    "clickRight": {
      "file": "calico-react-poke.apng",
      "duration": 2500
