{
  "schemaVersion": 1,
  "name": "Calico",
  "version": "1.0.0",
  "description": "A calico cat desk pet \u2014 AI-generated APNG animations",
  "viewBox": {
    "x": 0,
    "y": 0,
    "width": 266,
    "height": 200
  },
  "layout": {
    "contentBox": {
      "x": 36,
      "y": 10,
      "width": 194,
      "height": 160
    },
    "centerX": 133,
    "baselineY": 170,
    "visibleHeightRatio": 0.35,
    "baselineBottomRatio": 0.05
  },
  "eyeTracking": {
    "enabled": true,
    "states": [
      "idle"
    ],
    "eyeRatioX": 0.48,
    "eyeRatioY": 0.38,
    "maxOffset": 20,
    "trackingLayers": {
      "eyes": {
        "ids": [
          "eye-sockets",
          "eye-pupils",
          "eye-highlights"
        ],
        "maxOffset": 20,
        "ease": 0.2
      },
      "head": {
        "ids": [
          "outline-head",
          "base-head",
          "patch-head-right",
          "patch-head-left",
          "cheek-right",
          "cheek-left",
          "mouth",
          "whiskers-right",
          "ears-inner",
          "ear-inner-right",
          "ear-inner-left"
        ],
        "classes": [
          "ear-anim"
        ],
        "maxOffset": 12,
        "ease": 0.12
      },
      "body": {
        "ids": [
          "outline-body",
          "chest-head"
        ],
        "maxOffset": 3,
        "ease": 0.07
      }
    }
  },
  "states": {
    "idle": {
      "file": "calico-idle-follow.svg",
      "type": "svg"
    },
    "yawning": {
      "file": "calico-yawning.apng",
      "type": "apng"
    },
    "dozing": {
      "file": "calico-dozing.apng",
      "type": "apng"
    },
    "collapsing": {
      "file": "calico-collapsing.apng",
      "type": "apng"
    },
    "thinking": {
      "file": "calico-thinking.apng",
      "type": "apng"
    },
    "working": {
      "file": "calico-working-typing.apng",
      "type": "apng"
    },
    "juggling": {
      "file": "calico-working-juggling.apng",
      "type": "apng"
    },
    "sweeping": {
      "file": "calico-working-sweeping.apng",
      "type": "apng"
    },
    "error": {
      "file": "calico-error.apng",
      "type": "apng"
    },
    "attention": {
      "file": "calico-happy.apng",
      "type": "apng"
    },
    "notification": {
      "file": "calico-notification.apng",
      "type": "apng"
    },
    "carrying": {
      "file": "calico-working-carrying.apng",
      "type": "apng"
    },
    "sleeping": {
      "file": "calico-sleeping.apng",
      "type": "apng"
    },
    "waking": {
      "file": "calico-waking.apng",
      "type": "apng"
    }
  },
  "workingTiers": [
    {
      "minSessions": 3,
      "file": "calico-working-building.apng"
    },
    {
      "minSessions": 2,
      "file": "calico-working-juggling.apng"
    },
    {
      "minSessions": 1,
      "file": "calico-working-typing.apng"
    }
  ],
  "jugglingTiers": [
    {
      "minSessions": 2,
      "file": "calico-working-conducting.apng"
    },
    {
      "minSessions": 1,
      "file": "calico-working-juggling.apng"
    }
  ],
  "idleAnimations": [
    {
      "file": "calico-idle.apng",
      "duration": 5200
    }
  ],
  "displayHintMap": {
    "uma-working-building.svg": "calico-working-building.apng",
    "uma-working-typing.svg": "calico-working-typing.apng",
    "uma-headphones-groove.svg": "calico-working-juggling.apng",
    "uma-working-juggling.svg": "calico-working-juggling.apng",
    "uma-working-conducting.svg": "calico-working-conducting.apng",
    "uma-working-thinking.svg": "calico-thinking.apng"
  },
