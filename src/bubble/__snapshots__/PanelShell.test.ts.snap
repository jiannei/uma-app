// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PanelShell > Elicitation: renders AskPanelContent 1`] = `
"<div class="panel-layout">
  <div class="panel-header">
    <div class="icon-chip-small" style="background: var(--icon-chip-elicitation);">❓</div><span class="panel-title">Question</span><span class="panel-header-right"></span>
  </div>
  <div class="panel-body">
    <div class="ask-panel-content">
      <div class="question-container">
        <div class="question-title">Which test runner?</div>
        <div class="question-subtitle">Tests</div>
        <div class="options-list"><label class="option-label" tabindex="0">
            <div class="option-indicator radio">
              <!--v-if-->
            </div><span class="option-text">Vitest</span><span class="key-hint">1</span>
          </label><label class="option-label" tabindex="0">
            <div class="option-indicator radio">
              <!--v-if-->
            </div><span class="option-text">Jest</span><span class="key-hint">2</span>
          </label></div>
      </div>
      <div class="footer-buttons"><button class="footer-button back" disabled=""><span class="key-hint">←</span> Back </button><span style="flex-grow: 1; flex-shrink: 1; flex-basis: 0%;"></span><button class="footer-button deny"><span class="key-hint">esc</span> Deny </button><button class="footer-button primary">Submit <span class="key-hint">↵</span></button></div>
    </div>
  </div>
  <div class="panel-footer"></div>
</div>"
`;

exports[`PanelShell > PlanReview: renders PlanPanelContent 1`] = `
"<div class="panel-layout">
  <div class="panel-header">
    <div class="icon-chip-small" style="background: var(--icon-chip-planreview);">📋</div><span class="panel-title">Plan</span><span class="panel-header-right"></span>
  </div>
  <div class="panel-body">
    <div class="plan-panel-content">
      <div class="progress-section">
        <div class="progress-bar">
          <div class="progress-fill" style="width: 0%;"></div>
        </div>
        <div class="read-percent complete">✓ Got it</div>
      </div>
      <div class="plan-text"><pre>## Refactor auth
1. Extract middleware</pre>
      </div>
      <div class="feedback-section">
        <div class="feedback-label">Tell Claude what to change</div><textarea class="feedback-textarea" placeholder="What should Claude do differently?"></textarea>
      </div>
      <div class="footer-buttons"><span class="footer-hint">✓ Got it</span><span style="flex-grow: 1; flex-shrink: 1; flex-basis: 0%;"></span><button class="footer-button reject" disabled="">Reject</button><button class="footer-button approve">Approve</button></div>
    </div>
  </div>
  <div class="panel-footer"></div>
</div>"
`;
